{
    "name": "aliziodev/payid",
    "description": "Unified Laravel Payment Orchestrator for Indonesian Payment Gateways",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "payment",
        "gateway",
        "indonesia",
        "midtrans",
        "xendit",
        "doku",
        "ipaymu",
        "orchestrator"
    ],
    "authors": [
        {
            "name": "Alizio Dev",
            "email": "hello@aliziodev.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "laravel/pint": "^1.0",
        "larastan/larastan": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Aliziodev\\PayId\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aliziodev\\PayId\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aliziodev\\PayId\\PayIdServiceProvider"
            ],
            "aliases": {
                "PayId": "Aliziodev\\PayId\\Facades\\PayId"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "lint": "vendor/bin/pint",
        "lint-check": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
